# ==============================================================================
# PROYECTO DOS AROS - CONFIGURACIÓN COMPLETA DE ENTORNO
# ==============================================================================
# Este es un archivo PLANTILLA. Copia a .env y llena con tus valores reales.
# NUNCA commites .env (está en .gitignore)
#
# Documentación completa en: SECURITY.md
# ==============================================================================


# ==============================================================================
# SECCIÓN 1: BASES DE DATOS LOCALES
# ==============================================================================

LOCAL_DB=/mnt/nba_data/dosaros_local.db
PYTHONPATH=.


# ==============================================================================
# SECCIÓN 2: BASES DE DATOS REMOTAS (PostgreSQL, Supabase)
# ==============================================================================

# PostgreSQL Raspberry Pi (Red local)
DB_HOST=192.168.1.136
DB_PORT=5432
DB_NAME=proyecto_dos_aros
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# Supabase (Backup/Cloud - usar si es necesario)
SUPABASE_URL=https://bkjenzyygicqkunxvlyf.supabase.co
SUPABASE_KEY=su_key_aqui


# ==============================================================================
# SECCIÓN 3: COMUNICACIÓN (TELEGRAM, DISCORD)
# ==============================================================================

# Telegram Bot (para reportes diarios, alertas, interacción)
TELEGRAM_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Discord (futuro)
DISCORD_TOKEN=tu_token_aqui
DISCORD_CHANNEL_ID=tu_channel_id_aqui


# ==============================================================================
# SECCIÓN 4: LLMs - ANÁLISIS Y TEXTO
# ==============================================================================

# GOOGLE GEMINI (PRINCIPAL)
# Especialidad: Análisis masivo PBP, ventana de contexto enorme (1M tokens)
# Límite: 15 RPM, 1.500 req/día
# Docs: https://aistudio.google.com/
GEMINI_API_KEY=tu_key_aqui
GEMINI_MODEL=gemini-2.0-flash

# OpenAI ChatGPT
# Especialidad: JSON estricto, seguimiento de instrucciones complejas
# Límite: Según tier/suscripción
# Docs: https://platform.openai.com/
OPENAI_API_KEY=tu_key_aqui
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
# Especialidad: Razonamiento lógico, redacción humanizada (evita "palabras IA")
# Límite: Según suscripción
# Docs: https://console.anthropic.com/
CLAUDE_API_KEY=tu_key_aqui
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Groq (Llama 3 / Mixtral)
# Especialidad: Velocidad extrema (<1s) para Telegram real-time
# Límite: ~14.400 req/día, GENEROSO
# Docs: https://console.groq.com/
GROQ_API_KEY=tu_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# DeepSeek
# Especialidad: Matemáticas, codificación, scripts ETL
# Límite: 5M tokens al registrarse, muy barato post-gratis
# Docs: https://platform.deepseek.com/
DEEPSEEK_API_KEY=tu_key_aqui
DEEPSEEK_MODEL=deepseek-chat

# Kimi (Moonshot AI)
# Especialidad: Procesamiento de archivos largos, documentos NBA
# Límite: Nivel gratuito disponible
# Docs: https://platform.moonshot.cn/
KIMI_API_KEY=tu_key_aqui
KIMI_MODEL=moonshot-v1-128k

# X.AI (Grok)
# Especialidad: Tendencias en tiempo real de X / Twitter
# Límite: Early access, verificar disponibilidad
# Docs: https://console.x.ai/
GROK_API_KEY=tu_key_aqui
GROK_MODEL=grok-beta


# ==============================================================================
# SECCIÓN 5: GENERACIÓN DE IMÁGENES
# ==============================================================================

# Together AI (Flux.1 Schnell)
# Especialidad: Calidad fotográfica, texto legible en imágenes (Instagram posts)
# Límite: $5 crédito gratuito inicial (cientos de imágenes en Schnell)
# Docs: https://api.together.ai/
TOGETHER_API_KEY=tu_key_aqui
TOGETHER_MODEL=black-forest-labs/FLUX.1-schnell

# Pollinations AI (Free)
# Especialidad: Generación ilimitada sin registro
# Límite: Sin límite (Open Source)
# Docs: https://pollinations.ai/
POLLINATIONS_ENABLED=true
# No requiere KEY - acceso vía URL pública


# ==============================================================================
# SECCIÓN 6: AUDIO Y VOZ (TEXT-TO-SPEECH)
# ==============================================================================

# ElevenLabs
# Especialidad: Voz realista, narración de "Perlas de Datos"
# Límite: 10.000 caracteres/mes gratuito
# Docs: https://elevenlabs.io/api
ELEVENLABS_API_KEY=tu_key_aqui
ELEVENLABS_VOICE_ID=default

# Play.ht
# Especialidad: Clonación de voz, estabilidad en audios largos
# Límite: 5.000 palabras/mes nivel gratuito
# Docs: https://play.ht/
PLAYHT_API_KEY=tu_key_aqui


# ==============================================================================
# SECCIÓN 7: VÍDEO Y ANIMACIÓN
# ==============================================================================

# Luma AI (Dream Machine)
# Especialidad: Vídeos 5s realistas a partir de foto + prompt
# Límite: 30 generaciones/mes gratuito
# Docs: https://lumalabs.ai/dream-machine/api
LUMA_API_KEY=tu_key_aqui

# HeyGen
# Especialidad: Avatar de "Dos Aros" hablando (sincronización labial)
# Límite: 1 crédito gratuito
# Docs: https://www.heygen.com/api
HEYGEN_API_KEY=tu_key_aqui


# ==============================================================================
# SECCIÓN 8: SCRAPING Y DATOS DEPORTIVOS
# ==============================================================================

# NBA API (nba_api library - NO requiere KEY)
# Especialidad: Datos oficiales NBA históricos
# Límite: Rate limiting automático, ~50ms por request
NBA_API_ENABLED=true

# Euroliga API (euroleague_api library - NO requiere KEY)
# Especialidad: Datos Euroliga históricos
EURO_API_ENABLED=true

# Statsbomb (futuro - opcional)
STATSBOMB_API_KEY=tu_key_aqui


# ==============================================================================
# SECCIÓN 9: CONFIGURACIÓN LOCAL DE DESARROLLO
# ==============================================================================

# Ollama (IA local en tu PC/Pi)
# Modelos: gemma2:2b, llama3, etc.
# Docs: https://ollama.ai
OLLAMA_HOST=http://localhost:11434
OLLAMA_ENABLED=false

# Configuración de logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Modo desarrollo (activar debug)
DEBUG_MODE=false
